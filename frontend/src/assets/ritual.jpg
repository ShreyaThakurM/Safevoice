":\"upvote-feature-request-voting-board-template\",\"id\":\"upvote-feature-request-voting-board-template\",\"title\":\"Upvote\",\"pageTitle\":\"Upvote - Feature Request Board Template\",\"category\":\"Apps\",\"project_id\":\"c8e39c67-c008-412c-890e-638aae89bcb6\",\"url\":\"https://upvote-ideas.lovable.app\",\"subtitle\":\"Collaborative feature voting board where teams submit ideas, upvote priorities, and track requests from new to shipped\",\"description\":\"Collect and prioritize feature requests from your team. Submit ideas, upvote what matters most, track status from new to shipped, and let consensus drive your roadmap.\",\"metaTitle\":\"Upvote - Feature Request Board Template | Lovable\",\"metaDescription\":\"Collect and prioritize feature requests from your team. Submit ideas, upvote what matters most, track status from new to shipped, and let consensus drive your roadmap.\",\"subcategory\":\"product-management\",\"platform\":\"web\",\"screenshot\":\"https://storage.googleapis.com/lovable-assets/templates/upvote.jpg\",\"thumbnail\":\"https://storage.googleapis.com/lovable-assets/templates/upvote.jpg\",\"previewScreenshot\":\"https://storage.googleapis.com/lovable-assets/templates/upvote.jpg\",\"author\":{\"username\":\"Lovable\",\"avatar\":\"https://lovable.dev/img/logo/lovable-icon-bg-light.png\"},\"shownOn\":[\"templates\",\"dashboard-templates\"],\"date\":\"2026-04-09T00:00:00.000000\",\"lastModified\":\"2026-04-09T00:00:00.000000\",\"highlights\":[{\"icon\":\"lightbulb\",\"title\":\"Submit and vote on feature ideas\",\"description\":\"Anyone can propose an idea with a title, description, and category. The rest of the team votes it up or down.\"},{\"icon\":\"thumb_up\",\"title\":\"Upvote and downvote with real-time counts\",\"description\":\"Each request shows real-time upvote and downvote counts. Vote totals determine the default sort order so popular ideas surface first.\"},{\"icon\":\"task_alt\",\"title\":\"Status tracking from new to shipped\",\"description\":\"Requests move through statuses — new, under review, planned, in progress, and shipped. Admins update statuses as work progresses.\"},{\"icon\":\"forum\",\"title\":\"Threaded comments on each request\",\"description\":\"Leave comments on any request to discuss scope, add context, or raise concerns. Comment authors can delete their own comments.\"},{\"icon\":\"manage_accounts\",\"title\":\"Role-based access with admin controls\",\"description\":\"Three roles — admin, moderator, and user — control who can update statuses, edit requests, and moderate the board.\"},{\"icon\":\"filter_list\",\"title\":\"Filter, sort, and search requests\",\"description\":\"Search requests by title, sort by most votes or newest, and filter by category. Clear all filters with one click.\"}],\"features\":[{\"title\":\"Feature request submission\",\"description\":\"Submit ideas with a title, description, and optional category. Requests appear on the board instantly for the team to review.\"},{\"title\":\"Upvote and downvote voting\",\"description\":\"Each request shows real-time upvote and downvote counts. Vote totals determine the default sort order so the most popular ideas surface first.\"},{\"title\":\"Status tracking\",\"description\":\"Requests move through statuses — new, under review, planned, in progress, and shipped. Admins update statuses as work progresses.\"},{\"title\":\"Threaded comments\",\"description\":\"Leave comments on any request to discuss scope, add context, or raise concerns. Comment authors can delete their own comments.\"},{\"title\":\"Category filtering\",\"description\":\"Organize requests by category (design, backend, frontend, integrations, analytics). Filter the board to focus on a specific area.\"},{\"title\":\"Search and sort\",\"description\":\"Search requests by title, and sort by most votes or newest. Clear all filters with one click.\"},{\"title\":\"Role-based access control\",\"description\":\"Three roles — admin, moderator, and user — control who can update statuses, edit requests, and moderate the board.\"},{\"title\":\"Real-time updates\",\"description\":\"Vote counts and status changes update in real time via database subscriptions. No page refresh needed.\"},{\"title\":\"User profiles\",\"description\":\"Each user has a profile with name, email, and avatar. Submitter names appear on requests and comments.\"},{\"title\":\"Google OAuth login\",\"description\":\"Sign in with Google alongside email/password authentication. One-click login for teams already using Google Workspace.\"},{\"title\":\"Responsive design\",\"description\":\"Works on desktop, tablet, and mobile with adaptive layouts and a mobile-friendly navigation menu.\"},{\"title\":\"Customizable branding\",\"description\":\"Apply your brand colors and typography using the design system so the board feels like part of your product.\"}],\"content\":\"$3f\",\"relativePath\":\"upvote-feature-request-voting-board-template.md\"},{\"slug\":\"visual-landing-page-1\",\"id\":\"visual-landing-page-1\",\"title\":\"Visual Landing Page Website Template\",\"category\":\"Websites\",\"project_id\":\"1169db3a-30f3-49bc-bd0b-9cda42ae0ebe\",\"url\":\"https://ai-video-studio-landing-page.lovable.app\",\"subtitle\":\"Launch a cinematic studio website with full-screen video, custom animations, and integrated booking. Professional film aesthetics and 65+ UI components—go live in hours, not weeks.\",\"tagline\":\"Showcase your company\",\"description\":\"This template gives you a cinematic landing page for film and video production studios that looks professional and requires no design skills.\",\"metaTitle\":\"Visual Landing Page Website Template | Lovable\",\"metaDescription\":\"Launch a visually engaging landing page using a customisable no-code template.\",\"subcategory\":\"portfolio\",\"platform\":\"Web\",\"screenshot\":\"/templates/visual-landing-page-1-screenshot.webp\",\"thumbnail\":\"/templates/visual-landing-page-1-screenshot.webp\",\"previewScreenshot\":\"/t